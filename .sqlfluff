[sqlfluff]
dialect = postgres
max_line_length = 100
exclude_rules = L009

# ========================
# INDENTACIÓN
# ========================
[sqlfluff:indentation]
indent_unit = space
tab_space_size = 4

# ========================
# COMAS
# ========================
[sqlfluff:layout:type:comma]
line_position = trailing

# ========================
# REGLAS (NUEVO FORMATO)
# ========================

# Espaciado
[sqlfluff:rules:layout.spacing]
enabled = True

# Indentación
[sqlfluff:rules:layout.indent]
enabled = True

# Líneas largas
[sqlfluff:rules:layout.long_lines]
enabled = True

# Keywords en mayúsculas
[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = upper

# Identificadores consistentes
[sqlfluff:rules:capitalisation.identifiers]
enabled = True

# Alias obligatorios
[sqlfluff:rules:aliasing.expression]
require_alias = True
allow_scalar = False

# Alias únicos
[sqlfluff:rules:aliasing.unique.table]
enabled = True

# Evitar alias prohibidos
[sqlfluff:rules:aliasing.forbid]
enabled = True

# Referencias consistentes
[sqlfluff:rules:references.consistent]
enabled = True

# Evitar ambigüedad en columnas
[sqlfluff:rules:references.qualification]
enabled = True

# Uso correcto de keywords en referencias
[sqlfluff:rules:references.keywords]
enabled = True